{
  "name": "@departments/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API gateway — NestJS on :4000. Phase 3 adds the WS realtime hub (/ws) over the EventStream spine (Redis Streams in prod, resume-by-seq + dedupe + heartbeats). Auth/RBAC/RLS/GraphQL arrive in later phases. Full run needs the dev stack (docker compose up -d).",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@departments/shared": "workspace:*",
    "@departments/events": "workspace:*",
    "@departments/realtime": "workspace:*",
    "@departments/cost": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-ws": "^10.4.4",
    "@nestjs/websockets": "^10.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13"
  }
}
