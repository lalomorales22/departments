{
  "name": "@departments/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API gateway STUB — boots an empty NestJS app on :4000. Auth/RBAC/RLS/GraphQL+REST/WS-hub arrive in Phase 2+. Does not run without the Phase 1 dev stack (docker compose up -d).",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@departments/shared": "workspace:*",
    "@departments/events": "workspace:*",
    "@departments/cost": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
