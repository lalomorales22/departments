{
  "name": "@departments/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Temporal worker host. Registers the durable LoopWorkflow + activities and ticks the @departments/orchestration engine (PLAN→EXECUTE→EVALUATE→IMPROVE→MEMORY) one cycle per activity, with continue-as-new to keep history bounded.",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@departments/agent-runtime": "workspace:*",
    "@departments/artifacts": "workspace:*",
    "@departments/cost": "workspace:*",
    "@departments/events": "workspace:*",
    "@departments/memory": "workspace:*",
    "@departments/orchestration": "workspace:*",
    "@departments/rubrics": "workspace:*",
    "@departments/shared": "workspace:*",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
