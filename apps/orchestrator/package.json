{
  "name": "@departments/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workflow host STUB. The Temporal worker + LoopWorkflow land in Phase 2 (@temporalio/* deps added then). Phase 1 only logs and exits.",
