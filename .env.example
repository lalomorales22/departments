# DEPARTMENTS — environment template.
#
# Copy to `.env` and fill in. `.env*` is gitignored except this file.
# Defaults below match the Phase 1 dev stack (docker-compose.yml). Phase 1's UI
# is FIXTURE-driven, so most of these only matter once the gateway/orchestrator
# come online in Phase 2.
#
# SECRETS POLICY:
#   - In dev these are local toy creds. In prod they come from a Secret store.
#   - Encryption/KMS is a PLACEHOLDER here — no real KMS key is configured yet.
#   - Agent-facing credentials (the keys agents use to call external tools/APIs)
#     do NOT live in this file. They are stored, scoped, and rotated in the
#     per-org CMA Vaults and fetched at runtime. Keep tenant secrets out of env.

# ── Postgres (pgvector) ───────────────────────────────────────────────────────
# Primary store + RLS tenant boundary + embeddings.
DATABASE_URL=postgres://departments:departments@localhost:5432/departments

# ── Redis ─────────────────────────────────────────────────────────────────────
# Realtime spine (Redis Streams -> WS hub), cache, queues.
REDIS_URL=redis://localhost:6379

# ── Temporal ──────────────────────────────────────────────────────────────────
# Durable workflow engine for the orchestrator (Phase 2 worker host).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Object storage (S3 / Cloudflare R2; MinIO locally) ─────────────────────────
# Artifacts: deliverables, snapshots, large log blobs.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=departments-artifacts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# MinIO requires path-style addressing; real S3/R2 may not.
S3_FORCE_PATH_STYLE=true

# ── Model provider (the loop's cognition) ────────────────────────────────────────
# DEPARTMENTS_PROVIDER picks the runtime that actually drives a loop's thinking:
#   ollama  — a local model via the Ollama daemon (no cloud, no key, $0). Default when
#             OLLAMA_MODEL is set. List installed models: `curl localhost:11434/api/tags`.
#   claude  — the Anthropic Messages API (needs ANTHROPIC_API_KEY).
#   fake    — the deterministic offline runtime (demos/tests; no model call).
# When unset: a Claude key implies `claude`, else an Ollama model implies `ollama`,
# else `fake`. The cockpit's Settings → Provider pane forwards these per-run.
DEPARTMENTS_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# The DEFAULT pulled Ollama model (used for any role without an override below).
OLLAMA_MODEL=gemma4:12b-it-qat
# Optional per-role model overrides — a JSON map over planner/executor/reviewer/docs.
# Give judgment roles a stronger model and execution roles a faster one, e.g.:
# OLLAMA_ROLE_MODELS={"planner":"gemma4:26b","reviewer":"gemma4:26b","executor":"qwen3.5:2b","docs":"qwen3.5:2b"}

# Platform-level Anthropic key — enables the `claude` provider (direct Messages API).
# PLACEHOLDER; do not commit a real key. Agent/tenant keys are NOT here (CMA Vaults).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Optional: pin ONE Claude model for every role (else per-role tiering: Opus/Sonnet).
# CLAUDE_MODEL=claude-opus-4-8

# ── KMS (PLACEHOLDER) ──────────────────────────────────────────────────────────
# Envelope-encryption key id for secrets at rest. Not wired in Phase 1.
# KMS_KEY_ID=

# ── Gateway ─────────────────────────────────────────────────────────────────────
PORT=4000

# ── Web (browser-exposed; must be NEXT_PUBLIC_*) ──────────────────────────────
# WS endpoint the cockpit connects to for the realtime event stream.
NEXT_PUBLIC_WS_URL=ws://localhost:4000
